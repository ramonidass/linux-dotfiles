zinit light Aloxaf/fzf-tab

# Vi Mode Configuration & Plugin
ZVM_VI_INSERT_ESCAPE_BINDKEY=jj
ZVM_INSERT_MODE_CURSOR=$ZVM_CURSOR_BLINKING_BEAM
ZVM_NORMAL_MODE_CURSOR=$ZVM_CURSOR_BLINKING_BLOCK
zinit light jeffreytse/zsh-vi-mode

# Syntax & Autosuggestions (Must be loaded at the very end of plugins)
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# ==============================================================================
# ZSH OPTIONS & HISTORY CONFIGURATION
# ==============================================================================
setopt autocd              # Change directory just by typing its name
setopt interactivecomments # Allow comments in interactive shell lines
setopt promptsubst         # Enable command substitution in prompt
setopt appendhistory
setopt sharehistory
setopt extendedhistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_find_no_dups

HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=10'

# ==============================================================================
# COMPLETIONS & INTERACTIVE FZF-TAB SETUP
# ==============================================================================
autoload -Uz compinit bashcompinit
# Checks if .zcompdump was modified within the last 24 hours (m-1).
# If yes, skips time-consuming directory scans and loads the cache instantly via compinit -C.
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.m-1) ]]; then
    compinit -C
else
    compinit
fi
bashcompinit

zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no

# Check whether eza or standard ls should render inside fzf-tab previews
if command -v eza &> /dev/null; then
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath || ls -la $realpath'
    zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath || ls -la $realpath'
else
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls -la $realpath'
    zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls -la $realpath'
fi

# ==============================================================================
# TOOL INITIALIZATIONS
# ==============================================================================
# FZF Config
if command -v fzf &> /dev/null; then
    export FZF_DEFAULT_OPTS="--height 85% --layout=reverse --border=rounded \
      --preview 'bat --style=numbers --color=always --line-range :500 {} 2>/dev/null || cat {}' \
      --info=inline-right --ansi \
      --color=border:#27a1b9,fg:#c0caf5,gutter:#16161e,header:#ff9e64 \
      --color=hl+:#2ac3de,hl:#2ac3de,info:#545c7e,marker:#ff007c \
      --color=pointer:#ff007c,prompt:#2ac3de,query:#c0caf5:regular \
      --color=scrollbar:#27a1b9,separator:#ff9e64,spinner:#ff007c"
    eval "$(fzf --zsh)"
fi

# Zoxide (Smart directory jumping)
command -v zoxide &> /dev/null && eval "$(zoxide init zsh)"

# Direnv (Dynamic ENV loading)
command -v direnv &> /dev/null && eval "$(direnv hook zsh)" && export DIRENV_LOG_FORMAT=""

# Fastfetch (Welcome banner) - deferred to first precmd to avoid p10k warning
if command -v fastfetch &> /dev/null; then
    alias fastfetch='clear && command fastfetch'
    autoload -Uz add-zsh-hook
    function _fastfetch_once() {
        command fastfetch
        add-zsh-hook -d precmd _fastfetch_once
    }
    add-zsh-hook precmd _fastfetch_once
fi

# Docker Desktop (MacOS setup only)
if [[ -f "$HOME/.docker/init-zsh.sh" ]]; then
    source "$HOME/.docker/init-zsh.sh"
fi

