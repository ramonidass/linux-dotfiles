# --- SSH Agent Init ---
if [[ "$(uname -s)" == "Linux" ]]; then
    SSH_ENV="$HOME/.ssh/agent-environment"

    function start_agent {
        rm -f "$XDG_RUNTIME_DIR/ssh-agent.socket" 2>/dev/null
        /usr/bin/ssh-agent -t 2h -a "$XDG_RUNTIME_DIR/ssh-agent.socket" | sed 's/^echo/#echo/' > "${SSH_ENV}"
        chmod 600 "${SSH_ENV}"
        source "${SSH_ENV}" > /dev/null
    }

    # Force export the socket path so the ping-test knows where to look
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

    # Ping the agent safely by bypassing custom functions
    command ssh-add -l &>/dev/null
    if [[ $? -eq 2 ]]; then
        start_agent
    else
        # If alive, just source the environment to grab the PID
        [[ -f "${SSH_ENV}" ]] && source "${SSH_ENV}" > /dev/null
    fi

    # Export agent to Linux GUI environment (Systemd & DBus)
    if command -v dbus-update-activation-environment &>/dev/null; then
        dbus-update-activation-environment --systemd SSH_AUTH_SOCK SSH_AGENT_PID
    fi
fi

