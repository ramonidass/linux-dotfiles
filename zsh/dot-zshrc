# Ranger State Wrapper (Dynamic platform temp directory resolution)
function rr {
    local IFS=$'\t\n'
    local tempfile
    tempfile="$(mktemp -t tmp.XXXXXX || mktemp)"
    command ranger --cmd="map Q chain shell echo %d > \"$tempfile\"; quitall" "$@"
    if [[ -f "$tempfile" ]] && [[ "$(cat -- "$tempfile")" != "$PWD" ]]; then
        cd -- "$(cat "$tempfile")" || return
    fi
    command rm -f -- "$tempfile" 2>/dev/null
}

# --- SSH Key Manager & Tracker Functions ---
function ssh-add() {
    # If just passing a flag (like -l, -L, or -D), bypass the tracker
    if [[ "$1" == -* ]]; then
        command ssh-add "$@"
        return $?
    fi

    # If no arguments, default to the github key. (Daemon already handles the 2h timeout)
    if [ $# -eq 0 ]; then
        command ssh-add ~/.ssh/id_ed25519_github
    else
        command ssh-add "$@"
    fi

    # Record the timestamp if the key was successfully added
    if [ $? -eq 0 ]; then
        echo "$(date +%s)" > ~/.ssh/.key-loaded-at
        echo "🔑 Key lease tracked: Will expire in 2 hours."
    fi
}

# Command to check remaining lease time
function ssh-tl() {
    if ! command ssh-add -l >/dev/null 2>&1; then
        echo "🔓 No keys are currently loaded in the agent."
        return
    fi

    if [ -f ~/.ssh/.key-loaded-at ]; then
        local loaded_at=$(cat ~/.ssh/.key-loaded-at)
        local now=$(date +%s)
        local elapsed=$(( now - loaded_at ))
        local limit=7200 #sec
        local remaining=$(( limit - elapsed ))

        if [ $remaining -gt 0 ]; then
            local min=$(( remaining / 60 ))
            local sec=$(( remaining % 60 ))
            echo "🔑 Key is active. Time remaining: ${min}m ${sec}s"
        else
            echo "⌛ Key lease has expired (or was removed)."
        fi
    else
        echo "ℹ️ Key is loaded, but was added automatically in the background (no tracker data)."
    fi
}

