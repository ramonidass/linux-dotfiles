# Build unified PATH safely to avoid duplicates reloading
typeset -U path
path=(
    $HOME/.local/bin
    $HOME/.cargo/bin
    $GOPATH/bin
    $HOME/.config/bin
    /opt/homebrew/opt/libpq/bin
    $path
)
# Filters out non-existent directories on the fly.
# (N/) is a Zsh glob qualifier where 'N' enables NULL_GLOB and '/' filters for directories.
path=($^path(N/))
export PATH

# Database flags for compilers
if [[ -d "/opt/homebrew/opt/libpq" ]]; then
    export CPATH="/opt/homebrew/opt/libpq/include:$CPATH"
    export LIBRARY_PATH="/opt/homebrew/opt/libpq/lib:$LIBRARY_PATH"
fi

# Set default pager to bat if available
if command -v bat &> /dev/null; then
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"
    export PAGER=bat
fi

# Load Secrets securely from external file
if [[ -f "$HOME/.secrets.zsh" ]]; then
    source "$HOME/.secrets.zsh"
fi

