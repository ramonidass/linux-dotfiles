# Ranger State Wrapper (Dynamic platform temp directory resolution)
function rr {
    local IFS=$'\t\n'
    local tempfile
    tempfile="$(mktemp -t tmp.XXXXXX || mktemp)"
    command ranger --cmd="map Q chain shell echo %d > \"$tempfile\"; quitall" "$@"
    if [[ -f "$tempfile" ]] && [[ "$(cat -- "$tempfile")" != "$PWD" ]]; then
        cd -- "$(cat "$tempfile")" || return
    fi
    command rm -f -- "$tempfile" 2>/dev/null
}

# ==============================================================================
# BACKGROUND SERVICES (SSH Agent)
#
# Terminal
#  │
#  └───> Zsh runs your function: "start_agent"
#            │
#            └───> This starts the background daemon: "ssh-agent"
#                             (The daemon is now running, waiting silently)


#  ssh-add -t 2h
#              │
#              └───> "ssh-add" reads your key (~/.ssh/id_ed25519)
#              └───> It uploads the unlocked key into the running ssh-agent daemon for 2h
# ==============================================================================
SSH_ENV="$HOME/.ssh/agent-environment"

function start_agent {
    /usr/bin/ssh-agent | sed 's/^echo/#echo/' > "${SSH_ENV}"
    chmod 600 "${SSH_ENV}"
    source "${SSH_ENV}" > /dev/null
    # No automatic ssh-add here. Secure on-demand approach.
}

if [[ -f "${SSH_ENV}" ]]; then
    source "${SSH_ENV}" > /dev/null
    if [[ ! -S "$SSH_AUTH_SOCK" ]] || ! kill -0 "$SSH_AGENT_PID" 2>/dev/null; then
        start_agent
    fi
else
    start_agent
fi

alias ssh-add="ssh-add -t 2h"
